{
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "functions": {
    "api/*.js": {
      "maxDuration": 30
    },
    "api/cron/*.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/ths-sync",
      "schedule": "35 8 * * 1-5"
    },
    {
      "path": "/api/cron/daily-sync",
      "schedule": "45 8 * * 1-5"
    },
    {
      "path": "/api/cron/ths-feature-sync",
      "schedule": "55 8 * * 1-5"
    },
    {
      "path": "/api/cron/daily-signal-sync",
      "schedule": "10 9 * * 1-5"
    },
    {
      "path": "/api/cron/daily-signal-fallback",
      "schedule": "0 12 * * 1-5"
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    }
  ]
}
